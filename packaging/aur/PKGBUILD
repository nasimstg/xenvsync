# Maintainer: Md Nasim Sheikh <nasim.stg@gmail.com>
pkgname=xenvsync
pkgver=0.0.0.r0.g0000000
pkgrel=1
pkgdesc="Encrypt, commit, and inject .env secrets — no cloud required"
arch=('x86_64' 'aarch64')
url="https://github.com/nasimstg/xenvsync"
license=('MIT')
makedepends=('go' 'git')
source=("${pkgname}::git+https://github.com/nasimstg/xenvsync.git")
sha256sums=('SKIP')

pkgver() {
  cd "${pkgname}"
  local tag rev short
  tag="$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')"
  rev="$(git rev-list --count HEAD)"
  short="$(git rev-parse --short HEAD)"
  if [[ -z "${tag}" ]]; then
    tag="0.0.0"
  fi
  printf '%s.r%s.g%s\n' "${tag}" "${rev}" "${short}"
}

build() {
  cd "${pkgname}"
  export CGO_ENABLED=0
  go build -ldflags "-s -w -X main.version=${pkgver}" -o "${pkgname}" .
}

package() {
  cd "${pkgname}"
  install -Dm755 "${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
